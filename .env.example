# =============================================================================
# ORION Cognitive Agent - Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
#
# Stack: Python 3.12 + DeepAgents + langchain-aws + Bedrock
# Env values: local | bedrock | agentcore

# --- Environment ---
# Options:
#   local     -> metadata-only handle, sin invocacion a Bedrock (offline dev)
#   bedrock   -> invocacion real a AWS Bedrock via langchain-aws
#   agentcore -> wrapper para Bedrock AgentCore Runtime (Sprint futuro)
ORION_AGENT_ENVIRONMENT=local

# --- Logging ---
# DEBUG | INFO | WARNING | ERROR | CRITICAL
ORION_AGENT_LOG_LEVEL=INFO

# --- Model Configuration ---
# Provider: bedrock (unico soportado hoy; extensible en Sprint futuro)
ORION_AGENT_MODEL_PROVIDER=bedrock
# Model ID (Bedrock cross-region inference profile para Sonnet 4)
ORION_AGENT_MODEL_ID=us.anthropic.claude-sonnet-4-20250514
# AWS Region para Bedrock
ORION_AGENT_AWS_REGION=us-east-1

# --- Agent ---
# Nombre logico que aparece en LangSmith / AG-UI
ORION_AGENT_AGENT_NAME=orion-cognitive-agent
# Max LLM turns por sesion (LangGraph MessagesState length cap)
ORION_AGENT_MAX_TURNS=50

# --- AWS Credentials ---
# Si usas Bedrock, configura credenciales via:
# - AWS CLI (`aws configure`)
# - Variables de entorno estandar (AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY)
# - IAM Role (cuando corra en AWS infra: OIDC role `orion-agent-dev`)

# --- API Server (FastAPI + uvicorn) ---
ORION_AGENT_API_HOST=0.0.0.0
ORION_AGENT_API_PORT=8000
# Comma-separated JSON list of allowed origins (para dev con Angular local)
ORION_AGENT_CORS_ORIGINS=["http://localhost:4200"]

# --- Observability: LangSmith (opcional) ---
# Tracing del agente via LangChain auto-instrumentation. Activar solo cuando
# tengas credenciales; si esta en true sin API key, se loguea un warning y
# no se envia nada.
ORION_AGENT_LANGSMITH_TRACING=false
ORION_AGENT_LANGSMITH_PROJECT=orion-cognitive-agent
# Dejar vacio en CI / compartido. Setear localmente para depurar.
# ORION_AGENT_LANGSMITH_API_KEY=your-langsmith-api-key
