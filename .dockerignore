# =============================================================================
# ORION Cognitive Agent — .dockerignore
# =============================================================================
# Excluye todo lo no necesario en la imagen runtime de AgentCore (futuro).
# El Dockerfile hara `uv sync --no-dev` y dejara .venv + uv.lock +
# .python-version + src/ + README.md (para OpenAPI metadata).
# =============================================================================

# Version control
.git/
.gitignore
.gitattributes
.github/

# Python build / cache artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Test artifacts
tests/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.tox/
.nox/
.hypothesis/

# Type checker caches
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# Virtual environments (re-instalados dentro de la imagen)
.venv/
venv/
env/

# Secrets y config local
.env
.env.local
.env.*.local
.envrc

# IDE / editor
.idea/
.vscode/
.cursor/
.cursorignore
.cursorindexingignore
*.swp
*.swo
*~
.DS_Store

# Notebooks
.ipynb_checkpoints/

# LangChain / LangGraph caches
.langchain/
.langgraph/
traceloop/

# ML artifacts (deployados via S3, no embebidos en imagen)
models/*.pt
models/*.pth
models/*.h5
models/*.pkl
models/*.joblib
models/*.onnx
*.dvc
.dvc/
.dvcignore
dvc.lock

# MLflow / WandB
mlruns/
mlflow.db
mlflow.db-*
wandb/
.wandb/

# Bedrock / AgentCore local state
.agentcore/
.bedrock/
.bedrock-agentcore/

# Docs no necesarios en container (README queda como OpenAPI metadata)
CHANGELOG.md
IMPROVEMENTS.md

# Makefile (conveniencia host-side)
Makefile

# OS junk
Thumbs.db
desktop.ini
